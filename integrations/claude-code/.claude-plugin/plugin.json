{
  "name": "suboculo-claude-code",
  "description": "Suboculo integration for Claude Code - real-time monitoring of tool usage, agent spawns, and session events",
  "version": "0.1.0",
  "author": {
    "name": ""
  },
  "homepage": "https://github.com/your-org/suboculo",
  "repository": "https://github.com/your-org/suboculo",
  "license": "MIT",
  "mcpServers": {
    "suboculo": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/../../backend/mcp-analytics-server.mjs"],
      "env": {
        "SUBOCULO_DB_PATH": ".suboculo/events.db"
      }
    }
  }
}
